{
  "name": "your-app",
  "version": "1.0.0",
  "description": "记单词",
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development electron .",
    "build": "npm run build:python:mac && npm run build:render && npm run build:mac",
    "build:python:mac": "cd backend &&  pyinstaller python-backend.spec",
    "build:render": "cd src/render && npm run build",
    "build:mac": "electron-builder --mac --arm64",
    "pack:mac": "electron-builder --mac --dir"
  },
  "build": {
    "appId": "com.yourcompany.yourapp",
    "productName": "记单词",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "resources/**/*",
      "node_modules/**/*"
    ],
    "extraResources": [
      {
        "from": "backend/dist/python-backend",
        "to": "backend/python-backend"
      },
      {
        "from": "backend/.env",
        "to": "backend/.env"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": {
        "target": "default",
        "arch": [
          "arm64"
        ]
      },
      "icon": "resources/icon.icns",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "需要麦克风权限进行语音翻译",
        "NSCameraUsageDescription": "需要摄像头权限进行图像翻译"
      }
    }
  },
  "devDependencies": {
    "electron": "^37.0.0",
    "electron-builder": "^24.6.4"
  }
}